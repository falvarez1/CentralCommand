{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Debug",
      "Microsoft.Hosting.Lifetime": "Information",
      "CentralCommand": "Debug"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "InMemory",
    "Redis": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:8080"
    ]
  },
  "Authentication": {
    "Jwt": {
      "Enabled": false,
      "Issuer": "CentralCommand-Dev",
      "Audience": "CentralCommandAPI-Dev",
      "SecretKey": "DevelopmentSecretKey-MustBeAtLeast32CharactersLong!",
      "ExpirationMinutes": 1440
    },
    "ApiKey": {
      "Enabled": false,
      "ValidKeys": [
        "dev-api-key-1234567890"
      ]
    }
  },
  "SignalR": {
    "KeepAliveInterval": 15,
    "ClientTimeoutInterval": 30,
    "EnableDetailedErrors": true
  },
  "MetricsCollection": {
    "UpdateIntervalSeconds": 30,
    "MaxHistoryEntries": 100,
    "EnableAutoCollection": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Debug",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/centralcommand-dev-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}