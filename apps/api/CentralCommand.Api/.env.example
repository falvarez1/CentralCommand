# Central Command API Environment Variables
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=centralcommand
DATABASE_USER=postgres
# NEVER commit actual database password - use secrets management in production
DATABASE_PASSWORD=ChangeMeInProduction!

# JWT Configuration
# Generate a secure secret key (at least 256 bits / 32 characters)
# Use a cryptographically secure random generator in production
# Example command: openssl rand -base64 32
JWT_SECRET=ChangeThisToASecureRandomStringAtLeast32CharactersLong!
JWT_ISSUER=CentralCommand.API
JWT_AUDIENCE=CentralCommand.Client
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# Security Configuration
REQUIRE_HTTPS=true
ENABLE_RATE_LIMITING=true
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
RATE_LIMIT_WINDOW_MINUTES=1
RATE_LIMIT_MAX_REQUESTS=10

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://localhost:5173,https://yourdomain.com

# Session Configuration
SESSION_TIMEOUT_MINUTES=60
MAX_SESSION_LIFETIME_HOURS=24

# API Keys (for external services if needed)
# SENDGRID_API_KEY=your_sendgrid_api_key
# TWILIO_API_KEY=your_twilio_api_key

# Environment
ASPNETCORE_ENVIRONMENT=Production

# Logging
LOG_LEVEL=Information

# HSTS Configuration (production only)
HSTS_MAX_AGE_DAYS=365
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true